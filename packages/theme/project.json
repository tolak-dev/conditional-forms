{
  "name": "theme",
  "projectType": "library",
  "root": "packages/theme",
  "sourceRoot": "packages/theme/src",
  "targets": {
    "build": {
      "executor": "@nx/vite:build"
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": [],
      "options": {
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/theme/**/*.{ts,tsx}"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p packages/theme/tsconfig.lib.json"
      }
    }
  },
  "tags": []
}
